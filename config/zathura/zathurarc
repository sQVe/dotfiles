set selection-clipboard clipboard

# Catppuccin Latte theme (muted)
set default-bg "#d4d6de"
set default-fg "#1e2028"

set statusbar-bg "#c1c4cc"
set statusbar-fg "#1e2028"

set inputbar-bg "#c1c4cc"
set inputbar-fg "#1e2028"

set completion-bg "#adb0ba"
set completion-fg "#1e2028"
set completion-group-bg "#d4d6de"
set completion-group-fg "#5858a0"
set completion-highlight-bg "#5858a0"
set completion-highlight-fg "#d4d6de"

set notification-bg "#c1c4cc"
set notification-fg "#1e2028"
set notification-error-bg "#b82530"
set notification-error-fg "#d4d6de"
set notification-warning-bg "#806010"
set notification-warning-fg "#d4d6de"

set highlight-color "rgba(118, 120, 133, 0.5)"
set highlight-active-color "rgba(124, 50, 168, 0.5)"

set index-bg "#adb0ba"
set index-fg "#1e2028"
set index-active-bg "#5858a0"
set index-active-fg "#d4d6de"

set render-loading-bg "#d4d6de"
set render-loading-fg "#1e2028"

set recolor-lightcolor "#d4d6de"
set recolor-darkcolor "#1e2028"

# Disable instant quit
unmap q

# Command mode (Swedish keyboard)
map ö focus_inputbar ":"

# Navigation
map H goto top
map L goto bottom
map <Tab> navigate next
map <S-Tab> navigate previous

# Half-page scroll
map <C-d> scroll half-down
map <C-u> scroll half-up

# Jump history
map <C-o> jumplist backward
map <C-p> jumplist forward
