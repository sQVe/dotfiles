      "Bash(dirname:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(eslint:*)",
      "Bash(exa:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(fzf:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(grove:*)",
      "Bash(head:*)",
      "Bash(jest:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mage:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mulch:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(nvim:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(prettier:*)",
      "Bash(ps aux:*)",
      "Bash(pwd:*)",
      "Bash(pytest:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(rustc:*)",
      "Bash(rustfmt:*)",
      "Bash(rustup:*)",
      "Bash(sed:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(systemctl:*)",
      "Bash(tail:*)",
      "Bash(task:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(tsc:*)",
      "Bash(turbo:*)",
      "Bash(typst:*)",
      "Bash(uniq:*)",
      "Bash(vitest:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Edit",
      "ExitPlanMode",
      "Glob",
      "Grep",
      "KillShell",
      "LS",
      "MultiEdit",
      "Read",
      "Skill",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "test -d .mulch && mulch prime || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "test -d .mulch && mulch prime || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/sqve/scripts/claude/statusline.sh"
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "context7@claude-plugins-official": true,
    "elements-of-style@superpowers-marketplace": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "safety-net@cc-marketplace": true,
    "typescript-lsp@claude-plugins-official": true,
    "hyperpowers@withzombies-hyper": true,
    "notebox@notebox": true,
    "cape@cape": true
  },
  "extraKnownMarketplaces": {
    "withzombies-hyper": {
      "source": {
        "source": "directory",
        "path": "/home/sqve/code/forks/hyperpowers"
      }
    },
    "notebox": {
      "source": {
        "source": "directory",
        "path": "/home/sqve/notebox"
      }
    },
    "cape": {
      "source": {
        "source": "directory",
        "path": "/home/sqve/code/personal/cape"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754085535302
  },
  "effortLevel": "high"
}
