{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 7,
  "skillListingMaxDescChars": 2048,
  "skillListingBudgetFraction": 0.02,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "120000",
    "BROWSER": "google-chrome-stable",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(basename:*)",
      "Bash(bat:*)",
      "Bash(bd:*)",
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(delta:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(eslint:*)",
      "Bash(exa:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(fzf:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(grove:*)",
      "Bash(head:*)",
      "Bash(jest:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mage:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(nvim:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(prettier:*)",
      "Bash(ps aux:*)",
      "Bash(pwd:*)",
      "Bash(pytest:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(rustc:*)",
      "Bash(rustfmt:*)",
      "Bash(rustup:*)",
      "Bash(sed:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(systemctl:*)",
      "Bash(tail:*)",
      "Bash(task:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(tsc:*)",
      "Bash(turbo:*)",
      "Bash(typst:*)",
      "Bash(uniq:*)",
      "Bash(vitest:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Edit",
      "ExitPlanMode",
      "Glob",
      "Grep",
      "KillShell",
      "LS",
      "MultiEdit",
      "Read",
      "Skill",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && code-review-graph update --skip-flows",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && code-review-graph update --skip-flows",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/home/sqve/.claude/hooks/herdr-agent-state-guard.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/sqve/scripts/claude/statusline.sh"
  },
  "enabledPlugins": {
    "cape@cape": true,
    "context7@claude-plugins-official": false,
    "fallow@fallow-skills": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "improve@improve": true,
    "linear@claude-plugins-official": true,
    "notebox@notebox": true,
    "ponytail@ponytail": true,
    "posthog@claude-plugins-official": false,
    "safety-net@cc-marketplace": true,
    "slack@claude-plugins-official": true,
    "stop-slop@stop-slop": true,
    "typescript-lsp@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "cape": {
      "source": {
        "source": "directory",
        "path": "/home/sqve/code/personal/cape/main"
      }
    },
    "cc-marketplace": {
      "source": {
        "source": "github",
        "repo": "kenryu42/cc-marketplace"
      }
    },
    "fallow-skills": {
      "source": {
        "source": "github",
        "repo": "fallow-rs/fallow-skills"
      }
    },
    "improve": {
      "source": {
        "source": "github",
        "repo": "shadcn/improve"
      }
    },
    "notebox": {
      "source": {
        "source": "directory",
        "path": "/home/sqve/notebox"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "stop-slop": {
      "source": {
        "source": "directory",
        "path": "/home/sqve/.dotfiles/claude/plugins/stop-slop"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "verbose": true,
  "preferredNotifChannel": "kitty",
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754085535302
  },
  "lspServers": {
    "typescript": {
      "args": ["--stdio"],
      "command": "typescript-language-server",
      "extensionToLanguage": {
        ".cjs": "javascript",
        ".cts": "typescript",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".mts": "typescript",
        ".ts": "typescript",
        ".tsx": "typescriptreact"
      },
      "initializationOptions": {
        "maxTsServerMemory": 2048
      }
    }
  }
}
